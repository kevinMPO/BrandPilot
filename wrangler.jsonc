{
  // ───────────────────────────────────────────────────────────────────────
  // BrandPilot — Cloudflare Workers deploy config (via the OpenNext adapter).
  // See DEPLOY-CLOUDFLARE.md for the full walkthrough (incl. secrets + caveats).
  // Secrets (ANTHROPIC_API_KEY, BRIGHT_DATA_API_TOKEN, LINKUP_API_KEY) are set
  // with `wrangler secret put ...` — NEVER hard-coded here.
  // ───────────────────────────────────────────────────────────────────────
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "brandpilot",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
