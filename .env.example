# ─────────────────────────────────────────────────────────────────────────────
# BrandPilot — environment variables
# Copy this file to `.env.local` and fill in what you need.
# The app is designed to RUN WITH ZERO PAID KEYS (it falls back to realistic
# mocks), so you can `npm run dev` immediately and add keys later.
# ─────────────────────────────────────────────────────────────────────────────

# Which LLM powers the agent. Format: "<provider>/<model>".
# The code is model-agnostic: changing this value switches the model with NO
# code changes. Supported providers: anthropic, openai, mistral.
#   anthropic/claude-opus-4-8   (default)
#   openai/gpt-5.5
#   mistral/mistral-large
MODEL_PROVIDER=anthropic/claude-opus-4-8

# LLM API keys. You only need the ONE that matches MODEL_PROVIDER above.
# If NONE is set, the app runs a built-in "demo agent" that simulates a
# realistic ReAct loop so the live graph still works without any key.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# Bright Data MCP token for REAL web search (main writer grounding + Company
# Brain enrichment). OPTIONAL — if left empty, the web-search tool returns
# realistic MOCK results with the exact same shape, so the app works
# end-to-end without paying.
BRIGHT_DATA_API_TOKEN=

# Linkup API key for the INSPIRATION feature (idea discovery via the Linkup MCP
# server). OPTIONAL — if empty, Inspiration falls back to realistic MOCK ideas.
# Get one at https://app.linkup.so — NEVER commit the real value (use .env.local
# locally, or a Cloudflare/host secret in production).
LINKUP_API_KEY=

# Hard cap on ReAct loop iterations (tool-call rounds) so the agent can never
# loop forever. Default 6.
MAX_STEPS=6

# Model used by the CRITIC agent (format "<provider>/<model>"), so it can
# differ from the writer for a genuinely independent review (no self-preference
# bias). OPTIONAL — if empty, the critic defaults to a DIFFERENT Anthropic model
# than the writer (sonnet↔haiku), reusing your Anthropic key.
#   e.g. CRITIC_MODEL_PROVIDER=openai/gpt-5.5  (truly different provider)
CRITIC_MODEL_PROVIDER=

# Critic score (0-100) below which an angle is sent back to the writer for one
# automatic rewrite (critic → revision loop). Default 75.
REVISE_THRESHOLD=75

# Memory store path (Phase 4). Lightweight JSON file; swap for @mastra/memory
# (LibSQL/Postgres) later. Default .mastra/memory.json.
MEMORY_PATH=

# Evals (`npm run evals`) run fully OFFLINE on frozen fixtures (evals/fixtures.mjs)
# — no network, no key — so they're reproducible. No env var needed.
